# ─── REQUIRED: Supabase (the app cannot start without these) ─────────────────
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never NEXT_PUBLIC_

# ─── REQUIRED for AI scan (also REQUIRED IN PROD — see the fail-closed boot ──
# gate note below; unset in prod refuses to boot rather than persisting the
# synthetic dev-mode scan result as real donor inventory)
GEMINI_API_KEY=your-gemini-key

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED IN PRODUCTION (fail-closed boot gate — src/lib/env.ts, C2)
#
# Every var marked "REQUIRED IN PROD" below is checked by
# assertProductionEnv() (wired from src/instrumentation.ts). When
# NODE_ENV=production, the process refuses to boot if ANY of them is
# missing or empty — see src/lib/env.ts's REQUIRED_PROD_ENV list for the
# authoritative source of truth and the exact fail-open behavior each one
# guards against. Locally (NODE_ENV != production) they may all stay unset;
# every integration below falls back to the "dev mode" behavior noted inline.
# ═══════════════════════════════════════════════════════════════════════════

# Stripe — REQUIRED IN PROD (STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET)
# unset = payments simulated, payouts logged to console
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Base URL for Stripe Connect onboarding return links — defaults to localhost:3000 if unset
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Twilio Verify — REQUIRED IN PROD (all three vars)
# unset = OTP code is always 000000
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_VERIFY_SERVICE_SID=VA...

# OneSignal push — REQUIRED IN PROD (both vars)
# unset = notifications logged to console
# ONESIGNAL_APP_ID=...
# ONESIGNAL_REST_API_KEY=...

# Resend email — REQUIRED IN PROD (both vars)
# unset = emails logged to console
# RESEND_API_KEY=re_...
# EMAIL_FROM=FoodLink <onboarding@resend.dev>

# Rate limiting (Upstash) — REQUIRED IN PROD (both vars)
# unset = every rate limiter in src/lib/rate-limit.ts reports "allowed", i.e.
# no cap on OTP sends, login attempts, or Gemini-quota-spending scans.
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...

# Google Routes API — REQUIRED IN PROD
# unset = straight-line ETA estimate
# GOOGLE_ROUTES_API_KEY=...

# Smarty address validation — REQUIRED IN PROD (both vars)
# unset = any address accepted with Detroit-area coords
# NOTE: real delivery (Uber Direct) is gated on address_validated, which is only
# set when Smarty is actually configured — synthetic dev addresses never reach Uber.
# SMARTY_AUTH_ID=...
# SMARTY_AUTH_TOKEN=...

# ─── Delivery (Phase 3: Uber Direct + self-pickup) ────────────────────────────
# DELIVERY_MODE: 'uber' (default — provider deliveries + self-pickup) or
# 'internal' (re-enable the legacy in-house courier fleet + dispatch loop)
# DELIVERY_MODE=uber

# Uber Direct — unset = SimulatedProvider (fake quotes, timed status
# transitions; the full delivery loop works locally with no external deps).
# Sandbox is the default API base; set UBER_API_BASE=https://api.uber.com for prod.
# UBER_CUSTOMER_ID=...
# UBER_CLIENT_ID=...
# UBER_CLIENT_SECRET=...
# UBER_WEBHOOK_SECRET=...
# UBER_API_BASE=https://test-api.uber.com

# ─── Pivot: consumer marketplace (mothballed — ACTION_PLAN Q7) ────────────────
# The /consumer/* routes redirect to / unless explicitly re-enabled:
# NEXT_PUBLIC_CONSUMER_ENABLED=true

# Inngest — INNGEST_SIGNING_KEY is REQUIRED IN PROD (unsigned invocations
# otherwise reach src/app/api/inngest/route.ts unauthenticated).
# unset = works with `npx inngest-cli@latest dev` locally
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=...

# n8n webhooks — REQUIRED IN PROD (both vars)
# unset = outbound automations logged instead of sent, inbound n8n callbacks rejected
# N8N_WEBHOOK_BASE_URL=https://your-n8n.app.n8n.cloud/webhook
# N8N_WEBHOOK_SECRET=...

# ─── REQUIRED: Supabase (the app cannot start without these) ─────────────────
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never NEXT_PUBLIC_

# ─── REQUIRED for AI scan ─────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key

# ─── OPTIONAL: leave unset to run in simulated "dev mode" ─────────────────────
# Stripe — unset = payments simulated, payouts logged to console
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio Verify — unset = OTP code is always 000000
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_VERIFY_SERVICE_SID=VA...

# OneSignal push — unset = notifications logged to console
# ONESIGNAL_APP_ID=...
# ONESIGNAL_REST_API_KEY=...

# Google Routes API — unset = straight-line ETA estimate
# GOOGLE_ROUTES_API_KEY=...

# Smarty address validation — unset = any address accepted with Detroit-area coords
# SMARTY_AUTH_ID=...
# SMARTY_AUTH_TOKEN=...

# Inngest — unset = works with `npx inngest-cli@latest dev` locally
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=...

# n8n webhooks (optional external automations)
# N8N_WEBHOOK_BASE_URL=https://your-n8n.app.n8n.cloud/webhook
# N8N_WEBHOOK_SECRET=...

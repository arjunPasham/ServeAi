# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Next.js build artifacts ─────────────────────────────────────────────────
.next/
out/
build/

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Environment variables (NEVER commit secrets) ────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
# Allow committed example/template env files
!.env.example
!.env.*.example

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Testing & Coverage ──────────────────────────────────────────────────────
coverage/
.nyc_output/
/test-results/
/playwright-report/
/playwright/.cache/

# ─── Cache & Temp ────────────────────────────────────────────────────────────
.cache/
.turbo/
.eslintcache
.parcel-cache/
*.tmp
*.temp

# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── VS Code ─────────────────────────────────────────────────────────────────
# Ignore workspace-specific settings that shouldn't be shared
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
# Keep: .vscode/extensions.json (shared extension recommendations are useful)

# ─── Vercel / deployment ─────────────────────────────────────────────────────
.vercel/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ─── Claude Code (local session state only) ──────────────────────────────────
.claude/settings.local.json
.superpowers/
.next/
node_modules/
